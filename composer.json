{
    "name": "psc-acme/toolkit-catalog",
    "description": "Package toolkit-catalog for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ToolkitCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "brick/date-time": "^0.7.1",
        "illuminate/support": "^11.0",
        "symfony/validator": "^7.0",
        "predis/predis": "^2.0",
        "psc-acme/loader-product": "^1.0",
        "psc-acme/driver-product": "^1.0",
        "psc-acme/registry-product": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "webforge/object-asserter": "^2.0.0",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}